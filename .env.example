# Copy to .env and fill in. Every chat request validates the LLM_* block and
# returns a 500 with an actionable message if something is missing — there are
# no defaults and no fallbacks by design (one deployment = one model).
#
# MIGRATION NOTE: older versions of this app read CHAT_PROVIDER, GOOGLE_MODEL,
# ANTHROPIC_MODEL, GOOGLE_VERTEX_API_KEY, ANTHROPIC_API_KEY and
# GOOGLE_GENERATIVE_AI_API_KEY. Those names are NO LONGER READ — set the
# generic LLM_* vars below instead.

# ── LLM (required) ───────────────────────────────────────────────────────────

# Which provider SDK to use: openai | anthropic | google | vertex
LLM_PROVIDER=

# Provider-specific model id. Examples:
#   openai:    gpt-5.1, gpt-5-mini, gpt-4.1
#   anthropic: claude-opus-4-8, claude-sonnet-5, claude-haiku-4-5
#   google:    gemini-3.5-flash (AI Studio ids; free tier exists, but Pro
#              models are paid-only and 429 with limit:0 on the free tier)
#   vertex:    gemini-3.5-flash (Vertex ids can differ slightly from AI
#              Studio; Vertex is paid — no free tier)
LLM_MODEL=

# The provider API key, passed explicitly to the SDK (provider-specific env
# vars like ANTHROPIC_API_KEY are not read).
#   openai:    platform.openai.com key
#   anthropic: console.anthropic.com key
#   google:    Google AI Studio key
#   vertex:    a Vertex AI *express-mode* key (created in Vertex AI Studio —
#              NOT the same thing as an AI Studio key). Alternatively leave
#              empty and use the ADC block below.
LLM_API_KEY=

# ── Vertex via ADC (only when LLM_PROVIDER=vertex and LLM_API_KEY is empty) ──
# Authenticate with Application Default Credentials:
#   gcloud auth application-default login
# or point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON. Both
# project and location are required on this path.
# GOOGLE_VERTEX_PROJECT=
# GOOGLE_VERTEX_LOCATION=
# GOOGLE_APPLICATION_CREDENTIALS=

# ── Optional chat behavior ───────────────────────────────────────────────────

# Surface reasoning/"thinking" output for openai and anthropic models. Only
# set this for models that support it — the APIs REJECT the options otherwise:
#   openai:    reasoning models (gpt-5 family, o-series) → reasoningSummary
#   anthropic: claude-sonnet-4-6 and later → adaptive thinking
# Leave unset for e.g. gpt-4.1 or older Claude models. Gemini (google/vertex)
# reasoning is always requested and needs no flag.
# LLM_REASONING=true

# Replace the entire built-in system prompt (see api/chat/route.ts for the
# default — a data-analyst prompt tuned for the Nekt tools).
# CHAT_SYSTEM_PROMPT=

# Max agentic-loop steps per message (default 20). The final step always runs
# without tools so the model must produce a text answer.
# CHAT_MAX_STEPS=20

# ── MCP connection (optional prefills) ───────────────────────────────────────
# The MCP url + token always travel per-request from the browser. These
# NEXT_PUBLIC_ vars only prefill the standalone connect form — in embedded
# (iframe) mode the host supplies credentials via postMessage instead
# (see docs/iframe-message-contract.md).
# NEXT_PUBLIC_MCP_SERVER_URL=
# NEXT_PUBLIC_MCP_TOKEN=

# Comma-separated list of parent origins allowed to embed this app and talk
# to it via postMessage. Required for iframe mode; irrelevant standalone.
# NEXT_PUBLIC_ALLOWED_PARENT_ORIGINS=https://your-host-app.example.com
